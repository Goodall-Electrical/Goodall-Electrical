---
import Base from "../layouts/Base.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";

export const prerender = true;

const popular = [
  { label: "Home",                    href: "/" },
  { label: "All services",            href: "/services" },
  { label: "TV antennas — Gippsland", href: "/services/antennas" },
  { label: "Projects",                href: "/projects" },
  { label: "About",                   href: "/about" },
  { label: "Contact / request a quote", href: "/contact" },
];

const towns = [
  { name: "Sale",        href: "/services/antennas/sale" },
  { name: "Maffra",      href: "/services/antennas/maffra" },
  { name: "Stratford",   href: "/services/antennas/stratford" },
  { name: "Bairnsdale",  href: "/services/antennas/bairnsdale" },
  { name: "Traralgon",   href: "/services/antennas/traralgon" },
  { name: "Morwell",     href: "/services/antennas/morwell" },
];
---
<Base title="Page not found — Goodall Electrical" description="We couldn't find that page. Here's how to get to where you were heading.">

  <section class="relative overflow-hidden border-b border-ink-800 min-h-[60vh] flex items-center">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>

    <!-- Big background "404" -->
    <div aria-hidden="true" class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
      <span class="text-[20rem] md:text-[32rem] font-black text-ink-900/60 leading-none tracking-tighter">404</span>
    </div>

    <Container class="relative py-20 md:py-28">
      <div class="flex items-center gap-3">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full rounded-full bg-red-500 opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
        </span>
        <p class="text-spark-500 tracking-[0.3em] text-xs font-bold">NO SIGNAL · 404</p>
      </div>

      <h1 class="mt-4 text-5xl md:text-7xl font-extrabold tracking-tight leading-[0.95]">
        That circuit's<br />
        <span class="text-spark-500">not connected.</span>
      </h1>
      <p class="mt-6 text-bone-200 max-w-xl text-lg">
        The page you're after either moved, never existed, or has been quietly retired. Here are the most likely places you were heading.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="/">Back to home</Button>
        <Button href="/contact#quote-form" variant="ghost">Request a quote</Button>
      </div>
    </Container>
  </section>

  <!-- POPULAR LINKS -->
  <section class="border-b border-ink-800">
    <Container class="py-16 md:py-20 grid md:grid-cols-2 gap-16">
      <div>
        <p class="text-spark-500 text-xs font-bold tracking-[0.3em] uppercase">Popular pages</p>
        <ul class="mt-6 space-y-3">
          {popular.map((p) => (
            <li>
              <a href={p.href} class="group flex items-center justify-between border-b border-ink-800 py-3 text-bone-50 hover:text-spark-500 transition-colors">
                <span class="font-semibold">{p.label}</span>
                <span class="text-spark-500 group-hover:translate-x-1 transition-transform">→</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-spark-500 text-xs font-bold tracking-[0.3em] uppercase">Antenna service in your town</p>
        <ul class="mt-6 grid grid-cols-2 gap-3">
          {towns.map((t) => (
            <li>
              <a href={t.href} class="block border border-ink-800 px-4 py-3 text-bone-200 hover:border-spark-500 hover:text-spark-500 transition-colors text-sm font-semibold">
                {t.name}
              </a>
            </li>
          ))}
        </ul>
        <a href="/services/antennas" class="mt-6 inline-block text-spark-500 text-sm font-semibold hover:text-spark-600">All Gippsland towns →</a>
      </div>
    </Container>
  </section>

  <!-- CALL CTA -->
  <section class="py-16">
    <Container class="text-center">
      <p class="text-bone-400 text-sm">Still stuck? Just call us — we're easier to reach than the right URL.</p>
      <a href="tel:0341305012" class="mt-3 inline-block text-3xl md:text-4xl font-extrabold tracking-tight text-spark-500 hover:text-spark-600 whitespace-nowrap">03 4130 5012</a>
    </Container>
  </section>

</Base>
