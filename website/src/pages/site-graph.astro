---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Container from "../components/ui/Container.astro";
import { towns } from "../data/towns";
import { antennaTowns } from "../data/antenna-towns";
import { electricalTowns } from "../data/electrical-towns";

export const prerender = true;

type Group =
  | "core"
  | "service-hub"
  | "area-hub"
  | "antenna-town"
  | "electrical-town"
  | "blog"
  | "project"
  | "meta";

interface Node { id: string; label: string; group: Group; level?: number; }
interface Edge { from: string; to: string; }

const nodes: Node[] = [];
const edges: Edge[] = [];
const seen = new Set<string>();

function n(id: string, label: string, group: Group, level?: number) {
  if (seen.has(id)) return;
  seen.add(id);
  nodes.push({ id, label, group, level });
}
function e(from: string, to: string) { edges.push({ from, to }); }

// Levels drive the hierarchical layout (lower = closer to root)
n("/",             "Home",          "core",  0);
n("/services",     "Services",      "core",  1);
n("/areas",        "Service Areas", "core",  1);
n("/blog",         "Blog",          "core",  1);
n("/projects",     "Projects",      "core",  1);
n("/about",        "About",         "core",  1);
n("/contact",      "Contact",       "core",  4);
n("/testimonials", "Testimonials",  "core",  1);
n("/sitemap",      "Sitemap",       "meta",  1);

const serviceHubs = [
  { slug: "electrical",         label: "Electrical" },
  { slug: "audio-visual",       label: "Audio Visual" },
  { slug: "control-automation", label: "Control & Automation" },
  { slug: "communications",     label: "Communications" },
  { slug: "antennas",           label: "TV Antennas" },
];
for (const s of serviceHubs) n(`/services/${s.slug}`, s.label, "service-hub", 2);
for (const t of towns)         n(`/areas/${t.slug}`,            t.name,                "area-hub",        2);
for (const t of antennaTowns)  n(`/services/antennas/${t.slug}`,   `${t.name} (Antennas)`,   "antenna-town",    3);
for (const t of electricalTowns) n(`/services/electrical/${t.slug}`, `${t.name} (Electrical)`, "electrical-town", 3);

const posts = await getCollection("posts");
for (const p of posts) n(`/blog/${p.data.slug}`, p.data.title, "blog", 2);

const projects = await getCollection("projects");
for (const p of projects) n(`/projects/${p.data.slug}`, p.data.title, "project", 2);

// Edges (content links only)
e("/", "/contact");
for (const s of serviceHubs) e("/", `/services/${s.slug}`);
for (const p of projects.filter((x) => x.data.featured)) e("/", `/projects/${p.data.slug}`);

for (const s of serviceHubs) e("/services", `/services/${s.slug}`);
for (const s of serviceHubs) { e(`/services/${s.slug}`, "/contact"); e(`/services/${s.slug}`, "/projects"); }

for (const t of antennaTowns) e("/services/antennas", `/services/antennas/${t.slug}`);
for (const t of electricalTowns) e("/services/electrical", `/services/electrical/${t.slug}`);
for (const p of projects.filter((x) => x.data.services.includes("audio-visual"))) e("/services/audio-visual", `/projects/${p.data.slug}`);

for (const t of antennaTowns) {
  const me = `/services/antennas/${t.slug}`;
  e(me, "/services/antennas");
  e(me, "/contact");
  for (const slug of t.nearby) e(me, `/services/antennas/${slug}`);
}
for (const t of electricalTowns) {
  const me = `/services/electrical/${t.slug}`;
  e(me, "/services/electrical");
  e(me, "/contact");
  for (const slug of t.nearby) e(me, `/services/electrical/${slug}`);
}

for (const t of towns) e("/areas", `/areas/${t.slug}`);

const antennaSlugs = new Set(antennaTowns.map((t) => t.slug));
const electricalSlugs = new Set(electricalTowns.map((t) => t.slug));
for (const t of towns) {
  const me = `/areas/${t.slug}`;
  e(me, "/contact");
  e(me, electricalSlugs.has(t.slug) ? `/services/electrical/${t.slug}` : "/services/electrical");
  e(me, antennaSlugs.has(t.slug) ? `/services/antennas/${t.slug}` : "/services/antennas");
  e(me, "/services/audio-visual");
  e(me, "/services/control-automation");
  e(me, "/services/communications");
  for (const slug of t.nearby) e(me, `/areas/${slug}`);
}

for (const p of projects) e("/projects", `/projects/${p.data.slug}`);
for (const p of projects) { e(`/projects/${p.data.slug}`, "/contact"); e(`/projects/${p.data.slug}`, "/projects"); }

for (const p of posts) e("/blog", `/blog/${p.data.slug}`);
for (const p of posts) {
  const me = `/blog/${p.data.slug}`;
  e(me, "/contact");
  for (const r of posts) {
    if (r.data.slug === p.data.slug || r.data.category !== p.data.category) continue;
    e(me, `/blog/${r.data.slug}`);
  }
}

e("/about", "/contact");
e("/about", "/projects");
e("/contact", "/services/antennas");

const nodeCount = nodes.length;
const edgeCount = edges.length;
---
<Base title="Site graph — Goodall Electrical" description="Interactive visualisation of every page on the site and how they link to each other.">
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
    <Container class="relative py-12 md:py-16">
      <p class="text-spark-500 tracking-[0.3em] text-xs font-bold">SITE GRAPH · INTERNAL TOOL</p>
      <h1 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight leading-[1]">Page <span class="text-spark-500">flows.</span></h1>
      <p class="mt-4 text-bone-200 max-w-3xl">
        Every page and the content-area links between them. Header and footer nav aren't drawn — they connect every page to every other and would hide the actual structure. Use the filters below to toggle layers in and out.
      </p>
      <p class="mt-3 text-bone-400 text-sm">{nodeCount} pages · {edgeCount} content links · double-click a node to open the page.</p>
    </Container>
  </section>

  <!-- Filter / control bar -->
  <section class="border-b border-ink-800 bg-ink-950 sticky top-0 z-20" style="top: 73px;">
    <Container class="py-4 flex flex-wrap items-center gap-3">
      <span class="text-bone-400 text-xs tracking-[0.2em] uppercase font-bold">Show</span>
      <label class="filter-chip" data-group="core"><input type="checkbox" checked /> <span class="dot" style="background:#FFD60A"></span> Core</label>
      <label class="filter-chip" data-group="service-hub"><input type="checkbox" checked /> <span class="dot" style="background:#ef4444"></span> Service hubs</label>
      <label class="filter-chip" data-group="area-hub"><input type="checkbox" checked /> <span class="dot" style="background:#06b6d4"></span> Town hubs</label>
      <label class="filter-chip" data-group="antenna-town"><input type="checkbox" /> <span class="dot" style="background:#8b5cf6"></span> Antenna · town</label>
      <label class="filter-chip" data-group="electrical-town"><input type="checkbox" /> <span class="dot" style="background:#10b981"></span> Electrical · town</label>
      <label class="filter-chip" data-group="blog"><input type="checkbox" /> <span class="dot" style="background:#f97316"></span> Blog</label>
      <label class="filter-chip" data-group="project"><input type="checkbox" /> <span class="dot" style="background:#ec4899"></span> Projects</label>

      <span class="mx-2 h-6 w-px bg-ink-700"></span>

      <span class="text-bone-400 text-xs tracking-[0.2em] uppercase font-bold">Layout</span>
      <div class="layout-toggle inline-flex border border-ink-700 text-xs font-semibold">
        <button type="button" data-layout="hier" class="layout-btn px-3 py-1.5 active">Hierarchy</button>
        <button type="button" data-layout="force" class="layout-btn px-3 py-1.5">Force</button>
      </div>

      <span class="mx-2 h-6 w-px bg-ink-700"></span>

      <button type="button" id="fit-btn"   class="text-xs font-semibold border border-ink-700 px-3 py-1.5 hover:border-spark-500 hover:text-spark-500">Fit to view</button>
      <button type="button" id="reset-btn" class="text-xs font-semibold border border-ink-700 px-3 py-1.5 hover:border-spark-500 hover:text-spark-500">Reset filters</button>
    </Container>
  </section>

  <div id="site-graph" class="bg-ink-950" style="height: calc(100vh - 240px); min-height: 520px;"></div>

  <section class="border-t border-ink-800">
    <Container class="py-6 text-sm text-bone-400">
      <p><strong class="text-bone-50">Tips:</strong> scroll = zoom · drag a node to move · hover for in/out counts · <strong class="text-bone-50">double-click = open page</strong>.</p>
      <p class="mt-2">Defaults to the high-level skeleton (core + service hubs + town hubs). Toggle the per-town layers when you want to see the cross-link clusters.</p>
    </Container>
  </section>

  <script type="application/json" id="graph-data" set:html={JSON.stringify({ nodes, edges })}></script>

  <script is:inline src="https://unpkg.com/vis-network@9.1.9/standalone/umd/vis-network.min.js"></script>

  <script is:inline>
    (function () {
      const dataEl = document.getElementById("graph-data");
      const target = document.getElementById("site-graph");
      if (!dataEl || !target || typeof vis === "undefined") return;

      const raw = JSON.parse(dataEl.textContent || "{}");
      const groupStyles = {
        core:              { color: "#FFD60A", text: "#0a0a0a", weight: "bold", size: 16 },
        "service-hub":     { color: "#ef4444", text: "#fafaf7", weight: "bold", size: 18 },
        "area-hub":        { color: "#06b6d4", text: "#0a0a0a", weight: "normal", size: 14 },
        "antenna-town":    { color: "#8b5cf6", text: "#fafaf7", weight: "normal", size: 12 },
        "electrical-town": { color: "#10b981", text: "#0a0a0a", weight: "normal", size: 12 },
        blog:              { color: "#f97316", text: "#0a0a0a", weight: "bold",   size: 14 },
        project:           { color: "#ec4899", text: "#fafaf7", weight: "normal", size: 13 },
        meta:              { color: "#52525b", text: "#fafaf7", weight: "normal", size: 12 },
      };

      const outDeg = {}, inDeg = {};
      for (const ed of raw.edges) { outDeg[ed.from] = (outDeg[ed.from] || 0) + 1; inDeg[ed.to] = (inDeg[ed.to] || 0) + 1; }

      // Build node + edge datasets with our visual style baked in.
      const allNodes = new vis.DataSet(
        raw.nodes.map((n) => {
          const s = groupStyles[n.group] || groupStyles.meta;
          const deg = (outDeg[n.id] || 0) + (inDeg[n.id] || 0);
          return {
            id: n.id,
            label: n.label,
            group: n.group,
            level: n.level,
            shape: "box",
            margin: 8,
            widthConstraint: { maximum: 180 },
            color: { background: s.color, border: s.color, highlight: { background: s.color, border: "#FFD60A" } },
            font: { color: s.text, face: "system-ui", size: s.size, bold: s.weight === "bold" },
            borderWidth: 0,
            borderWidthSelected: 3,
            title: `${n.label}\n${n.id}\nin:${inDeg[n.id] || 0} · out:${outDeg[n.id] || 0}`,
            _degree: deg,
          };
        })
      );
      const allEdges = new vis.DataSet(
        raw.edges.map((ed, i) => ({
          id: i,
          from: ed.from,
          to: ed.to,
          arrows: { to: { enabled: true, scaleFactor: 0.5 } },
          color: { color: "rgba(214,212,204,0.18)", highlight: "#FFD60A", hover: "#FFD60A" },
          smooth: { type: "cubicBezier", roundness: 0.35 },
        }))
      );

      // Visible state — copies of the master that we'll filter from.
      const visibleNodes = new vis.DataSet(allNodes.get());
      const visibleEdges = new vis.DataSet(allEdges.get());

      const baseOpts = {
        interaction: { hover: true, tooltipDelay: 100, navigationButtons: false, keyboard: false, zoomView: true, dragView: true },
        edges: { width: 1, hoverWidth: 2, selectionWidth: 2 },
        nodes: { borderWidth: 0 },
      };

      let layout = "hier";
      function makeOptions(layoutMode) {
        if (layoutMode === "hier") {
          return Object.assign({}, baseOpts, {
            layout: { hierarchical: { enabled: true, direction: "UD", sortMethod: "directed", levelSeparation: 160, nodeSpacing: 140, treeSpacing: 200, blockShifting: true, edgeMinimization: true, parentCentralization: true } },
            physics: { enabled: false },
            edges: Object.assign({}, baseOpts.edges, { smooth: { type: "cubicBezier", forceDirection: "vertical", roundness: 0.4 } }),
          });
        }
        return Object.assign({}, baseOpts, {
          layout: { hierarchical: false, improvedLayout: true },
          physics: {
            enabled: true,
            solver: "forceAtlas2Based",
            forceAtlas2Based: { gravitationalConstant: -120, centralGravity: 0.015, springLength: 120, springConstant: 0.05, damping: 0.5, avoidOverlap: 0.7 },
            stabilization: { enabled: true, iterations: 300, updateInterval: 25, fit: true },
          },
          edges: Object.assign({}, baseOpts.edges, { smooth: { type: "continuous", roundness: 0.2 } }),
        });
      }

      const network = new vis.Network(target, { nodes: visibleNodes, edges: visibleEdges }, makeOptions(layout));
      network.once("stabilizationIterationsDone", () => network.fit());

      function applyFilters() {
        const visibleGroups = new Set();
        document.querySelectorAll(".filter-chip input").forEach((cb) => {
          if (cb.checked) visibleGroups.add(cb.closest(".filter-chip").dataset.group);
        });
        const keepIds = new Set(allNodes.get().filter((n) => visibleGroups.has(n.group)).map((n) => n.id));
        visibleNodes.clear();
        visibleNodes.add(allNodes.get().filter((n) => keepIds.has(n.id)));
        visibleEdges.clear();
        visibleEdges.add(allEdges.get().filter((ed) => keepIds.has(ed.from) && keepIds.has(ed.to)));
        setTimeout(() => network.fit({ animation: { duration: 400, easingFunction: "easeInOutQuad" } }), 50);
      }

      function setLayout(next) {
        if (next === layout) return;
        layout = next;
        document.querySelectorAll(".layout-btn").forEach((b) => b.classList.toggle("active", b.dataset.layout === next));
        network.setOptions(makeOptions(layout));
        setTimeout(() => network.fit({ animation: { duration: 400, easingFunction: "easeInOutQuad" } }), 50);
      }

      document.querySelectorAll(".filter-chip input").forEach((cb) => cb.addEventListener("change", applyFilters));
      document.querySelectorAll(".layout-btn").forEach((b) => b.addEventListener("click", () => setLayout(b.dataset.layout)));
      document.getElementById("fit-btn").addEventListener("click", () => network.fit({ animation: { duration: 400, easingFunction: "easeInOutQuad" } }));
      document.getElementById("reset-btn").addEventListener("click", () => {
        document.querySelectorAll(".filter-chip input").forEach((cb) => {
          const g = cb.closest(".filter-chip").dataset.group;
          cb.checked = (g === "core" || g === "service-hub" || g === "area-hub");
        });
        applyFilters();
      });

      // Highlight a node + its neighbours on click
      network.on("click", (params) => {
        if (!params.nodes.length) return;
        const id = params.nodes[0];
        const connected = new Set([id]);
        allEdges.get().forEach((ed) => { if (ed.from === id) connected.add(ed.to); if (ed.to === id) connected.add(ed.from); });
        visibleNodes.update(visibleNodes.get().map((n) => ({ id: n.id, opacity: connected.has(n.id) ? 1 : 0.15 })));
      });
      network.on("deselectNode", () => {
        visibleNodes.update(visibleNodes.get().map((n) => ({ id: n.id, opacity: 1 })));
      });

      network.on("doubleClick", (params) => {
        if (params.nodes && params.nodes[0]) window.open(params.nodes[0], "_blank");
      });

      // Default to skeleton view
      applyFilters();
    })();
  </script>

  <style is:global>
    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.7rem;
      border: 1px solid var(--color-ink-700);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      cursor: pointer;
      user-select: none;
      color: var(--color-bone-200);
      transition: border-color 150ms, color 150ms;
    }
    .filter-chip:hover { border-color: var(--color-spark-500); color: var(--color-spark-500); }
    .filter-chip input { accent-color: var(--color-spark-500); cursor: pointer; }
    .filter-chip .dot { display: inline-block; width: 0.6rem; height: 0.6rem; border-radius: 9999px; }
    .filter-chip:has(input:checked) { border-color: var(--color-bone-50); color: var(--color-bone-50); }

    .layout-btn { background: transparent; color: var(--color-bone-200); cursor: pointer; transition: background 120ms, color 120ms; }
    .layout-btn + .layout-btn { border-left: 1px solid var(--color-ink-700); }
    .layout-btn:hover { color: var(--color-spark-500); }
    .layout-btn.active { background: var(--color-spark-500); color: var(--color-ink-950); }
  </style>
</Base>
