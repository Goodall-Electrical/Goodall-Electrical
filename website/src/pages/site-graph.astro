---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Container from "../components/ui/Container.astro";
import { towns } from "../data/towns";
import { antennaTowns } from "../data/antenna-towns";
import { electricalTowns } from "../data/electrical-towns";

export const prerender = true;

// ── Node/edge model ─────────────────────────────────────────────────
// Categories drive node colour + the legend below.
type Group =
  | "core"
  | "service-hub"
  | "area-hub"
  | "antenna-town"
  | "electrical-town"
  | "blog"
  | "project"
  | "meta";

interface Node { id: string; label: string; group: Group; }
interface Edge { from: string; to: string; }

const nodes: Node[] = [];
const edges: Edge[] = [];
const seen = new Set<string>();

function n(id: string, label: string, group: Group) {
  if (seen.has(id)) return;
  seen.add(id);
  nodes.push({ id, label, group });
}
function e(from: string, to: string) {
  edges.push({ from, to });
}

// ── Static / core pages ────────────────────────────────────────────
n("/",             "Home",          "core");
n("/about",        "About",         "core");
n("/contact",      "Contact",       "core");
n("/projects",     "Projects",      "core");
n("/testimonials", "Testimonials",  "core");
n("/blog",         "Blog",          "core");
n("/areas",        "Service Areas", "core");
n("/services",     "Services",      "core");
n("/sitemap",      "Sitemap",       "meta");

// ── Service hubs ──────────────────────────────────────────────────
const serviceHubs = [
  { slug: "electrical",         label: "Electrical" },
  { slug: "audio-visual",       label: "Audio Visual" },
  { slug: "control-automation", label: "Control & Automation" },
  { slug: "communications",     label: "Communications" },
  { slug: "antennas",           label: "TV Antennas" },
];
for (const s of serviceHubs) n(`/services/${s.slug}`, s.label, "service-hub");

// ── Areas (town hubs) ────────────────────────────────────────────
for (const t of towns) n(`/areas/${t.slug}`, t.name, "area-hub");

// ── Per-town antenna pages ───────────────────────────────────────
for (const t of antennaTowns) n(`/services/antennas/${t.slug}`, `${t.name} · Antennas`, "antenna-town");

// ── Per-town electrical pages ────────────────────────────────────
for (const t of electricalTowns) n(`/services/electrical/${t.slug}`, `${t.name} · Electrical`, "electrical-town");

// ── Blog posts ───────────────────────────────────────────────────
const posts = await getCollection("posts");
for (const p of posts) n(`/blog/${p.data.slug}`, p.data.title, "blog");

// ── Project pages ────────────────────────────────────────────────
const projects = await getCollection("projects");
for (const p of projects) n(`/projects/${p.data.slug}`, p.data.title, "project");

// ── Edges (content links — excludes universal header/footer) ─────

// Home page hero + sections
e("/", "/contact");          // Get a quote CTA
for (const s of serviceHubs) e("/", `/services/${s.slug}`);  // services snapshot tiles
for (const p of projects.filter((x) => x.data.featured)) e("/", `/projects/${p.data.slug}`);  // featured projects

// Services hub → each service hub
for (const s of serviceHubs) e("/services", `/services/${s.slug}`);

// Per-service hubs
for (const s of serviceHubs) {
  e(`/services/${s.slug}`, "/contact");          // quote CTA
  e(`/services/${s.slug}`, "/projects");         // see our work
}
// Antennas → 20 town pages
for (const t of antennaTowns) e("/services/antennas", `/services/antennas/${t.slug}`);
// Electrical → 20 town pages
for (const t of electricalTowns) e("/services/electrical", `/services/electrical/${t.slug}`);
// AV pulls AV-tagged projects
for (const p of projects.filter((x) => x.data.services.includes("audio-visual"))) {
  e("/services/audio-visual", `/projects/${p.data.slug}`);
}

// Per-town antenna pages → 4 nearby antenna town pages + back to hub + contact
for (const t of antennaTowns) {
  const me = `/services/antennas/${t.slug}`;
  e(me, "/services/antennas");
  e(me, "/contact");
  for (const slug of t.nearby) e(me, `/services/antennas/${slug}`);
}

// Per-town electrical pages → 4 nearby + back to hub + contact
for (const t of electricalTowns) {
  const me = `/services/electrical/${t.slug}`;
  e(me, "/services/electrical");
  e(me, "/contact");
  for (const slug of t.nearby) e(me, `/services/electrical/${slug}`);
}

// Areas index → 20 area hubs
for (const t of towns) e("/areas", `/areas/${t.slug}`);

// Each areas/<town> → 5 services (service-town page where it exists, else service hub) + 4 nearby areas + contact
const antennaSlugs = new Set(antennaTowns.map((t) => t.slug));
const electricalSlugs = new Set(electricalTowns.map((t) => t.slug));
for (const t of towns) {
  const me = `/areas/${t.slug}`;
  e(me, "/contact");
  // Electrical → town-specific if exists
  e(me, electricalSlugs.has(t.slug) ? `/services/electrical/${t.slug}` : "/services/electrical");
  // Antennas → town-specific if exists
  e(me, antennaSlugs.has(t.slug) ? `/services/antennas/${t.slug}` : "/services/antennas");
  // AV / Automation / Comms → hub only
  e(me, "/services/audio-visual");
  e(me, "/services/control-automation");
  e(me, "/services/communications");
  // Nearby town hubs
  for (const slug of t.nearby) e(me, `/areas/${slug}`);
}

// Projects index → each project
for (const p of projects) e("/projects", `/projects/${p.data.slug}`);
// Project pages → contact + back to projects
for (const p of projects) {
  const me = `/projects/${p.data.slug}`;
  e(me, "/contact");
  e(me, "/projects");
}

// Blog index → each post
for (const p of posts) e("/blog", `/blog/${p.data.slug}`);
// Blog posts → contact + related posts (same category)
for (const p of posts) {
  const me = `/blog/${p.data.slug}`;
  e(me, "/contact");
  for (const r of posts) {
    if (r.data.slug === p.data.slug) continue;
    if (r.data.category !== p.data.category) continue;
    e(me, `/blog/${r.data.slug}`);
  }
}

// About → contact, projects (hero CTAs)
e("/about", "/contact");
e("/about", "/projects");

// Contact → service area teaser
e("/contact", "/services/antennas");

// ── Summary counters for the page header ─────────────────────────
const nodeCount = nodes.length;
const edgeCount = edges.length;
---
<Base title="Site graph — Goodall Electrical" description="Interactive visualisation of every page on the site and how they link to each other through the content (not the universal nav).">
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
    <Container class="relative py-16 md:py-20">
      <p class="text-spark-500 tracking-[0.3em] text-xs font-bold">SITE GRAPH · INTERNAL TOOL</p>
      <h1 class="mt-3 text-4xl md:text-6xl font-extrabold tracking-tight leading-[1]">Page <span class="text-spark-500">flows.</span></h1>
      <p class="mt-6 text-bone-200 max-w-3xl text-lg">
        Every page on the site, with edges drawn for content-area links between them (hero CTAs, service tiles, town cross-links, related posts). Header and footer links aren't drawn — they apply to every page and would obliterate the signal. Drag nodes around, scroll to zoom, click a node to open the page.
      </p>
      <p class="mt-4 text-bone-400 text-sm">{nodeCount} pages · {edgeCount} content-area links · regenerated on every build.</p>
    </Container>
  </section>

  <section class="border-b border-ink-800">
    <Container class="py-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
      <span class="text-bone-400 tracking-[0.2em] text-xs uppercase">Legend</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#FFD60A"></span>Core</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#ef4444"></span>Service hub</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#06b6d4"></span>Town hub (/areas)</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#8b5cf6"></span>Antenna · town</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#10b981"></span>Electrical · town</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#f97316"></span>Blog post</span>
      <span class="flex items-center gap-2"><span class="w-3 h-3 rounded-full" style="background:#ec4899"></span>Project</span>
    </Container>
  </section>

  <!-- Graph canvas — full-bleed, takes the remaining viewport. -->
  <div id="site-graph" class="bg-ink-950" style="height: 78vh; min-height: 600px;"></div>

  <script type="application/json" id="graph-data" set:html={JSON.stringify({ nodes, edges })}></script>

  <script is:inline src="https://unpkg.com/vis-network@9.1.9/standalone/umd/vis-network.min.js"></script>

  <script is:inline>
    (function () {
      const dataEl = document.getElementById("graph-data");
      const target = document.getElementById("site-graph");
      if (!dataEl || !target || typeof vis === "undefined") return;

      const raw = JSON.parse(dataEl.textContent || "{}");
      const groupStyles = {
        core:            { color: { background: "#FFD60A", border: "#FFD60A" }, font: { color: "#0a0a0a", face: "system-ui", size: 14, bold: true } },
        "service-hub":   { color: { background: "#ef4444", border: "#ef4444" }, font: { color: "#fafaf7", face: "system-ui", size: 13, bold: true } },
        "area-hub":      { color: { background: "#06b6d4", border: "#06b6d4" }, font: { color: "#0a0a0a", face: "system-ui", size: 12 } },
        "antenna-town":  { color: { background: "#8b5cf6", border: "#8b5cf6" }, font: { color: "#fafaf7", face: "system-ui", size: 11 } },
        "electrical-town": { color: { background: "#10b981", border: "#10b981" }, font: { color: "#0a0a0a", face: "system-ui", size: 11 } },
        blog:            { color: { background: "#f97316", border: "#f97316" }, font: { color: "#0a0a0a", face: "system-ui", size: 12, bold: true } },
        project:         { color: { background: "#ec4899", border: "#ec4899" }, font: { color: "#fafaf7", face: "system-ui", size: 12 } },
        meta:            { color: { background: "#52525b", border: "#52525b" }, font: { color: "#fafaf7", face: "system-ui", size: 11 } },
      };

      // Size nodes by their out-degree so high-link pages stand out.
      const outDegree = {};
      for (const ed of raw.edges) outDegree[ed.from] = (outDegree[ed.from] || 0) + 1;
      const inDegree = {};
      for (const ed of raw.edges) inDegree[ed.to] = (inDegree[ed.to] || 0) + 1;

      const nodes = new vis.DataSet(
        raw.nodes.map((n) => {
          const style = groupStyles[n.group] || groupStyles.meta;
          const score = (outDegree[n.id] || 0) + (inDegree[n.id] || 0);
          return {
            id: n.id,
            label: n.label,
            shape: "dot",
            size: Math.min(8 + score * 0.6, 36),
            color: style.color,
            font: style.font,
            title: `${n.label} (${n.id}) — in:${inDegree[n.id] || 0} out:${outDegree[n.id] || 0}`,
          };
        })
      );
      const edges = new vis.DataSet(
        raw.edges.map((ed, i) => ({
          id: i,
          from: ed.from,
          to: ed.to,
          arrows: "to",
          color: { color: "rgba(214,212,204,0.18)", highlight: "#FFD60A", hover: "#FFD60A" },
          smooth: { type: "continuous", roundness: 0.2 },
        }))
      );

      const network = new vis.Network(target, { nodes, edges }, {
        layout: { improvedLayout: true },
        physics: {
          enabled: true,
          solver: "forceAtlas2Based",
          forceAtlas2Based: {
            gravitationalConstant: -80,
            centralGravity: 0.01,
            springLength: 110,
            springConstant: 0.04,
            damping: 0.45,
            avoidOverlap: 0.6,
          },
          stabilization: { enabled: true, iterations: 400, updateInterval: 25, fit: true },
        },
        interaction: { hover: true, tooltipDelay: 80, navigationButtons: false, keyboard: false, zoomView: true },
        nodes: { borderWidth: 0 },
        edges: { width: 1, hoverWidth: 2 },
      });

      // Once the layout settles, freeze the physics so dragging is responsive.
      network.once("stabilizationIterationsDone", () => {
        network.setOptions({ physics: false });
      });

      // Click a node = open the page in a new tab.
      network.on("doubleClick", (params) => {
        if (params.nodes && params.nodes[0]) window.open(params.nodes[0], "_blank");
      });
      network.on("selectNode", (params) => {
        // Single-click highlights connected nodes; double-click opens the page.
        if (!params.nodes[0]) return;
      });
    })();
  </script>

  <section class="border-t border-ink-800">
    <Container class="py-8 text-sm text-bone-400">
      <p><strong class="text-bone-50">Tips:</strong> drag a node to reposition it · scroll to zoom · hover for in/out-link counts · <strong class="text-bone-50">double-click a node to open that page</strong> in a new tab.</p>
      <p class="mt-2">Bigger nodes = pages with more total content links (in + out). Yellow = core landing pages. Red = service hubs. Cyan = town hubs. Purple = per-town antennas. Green = per-town electrical.</p>
    </Container>
  </section>
</Base>
