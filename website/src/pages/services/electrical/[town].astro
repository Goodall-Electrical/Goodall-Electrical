---
import Base from "../../../layouts/Base.astro";
import Container from "../../../components/ui/Container.astro";
import Button from "../../../components/ui/Button.astro";
import SectionHeading from "../../../components/ui/SectionHeading.astro";
import { electricalTowns, type ElectricalTown } from "../../../data/electrical-towns";
import { business } from "../../../data/business";

const rates = business.antennaRates;

export const prerender = true;

export async function getStaticPaths() {
  return electricalTowns.map((town) => ({
    params: { town: town.slug },
    props: { town },
  }));
}

interface Props { town: ElectricalTown; }
const { town } = Astro.props;

const title = `Electrician in ${town.name} | Goodall Electrical`;
const description = `Licensed electrician serving ${town.name} (${town.postcode ?? "Gippsland"}). Switchboard upgrades, EV chargers, three-phase, lighting, point additions, compliance. Call ${business.phone.display}.`;

const faqs = [
  {
    q: `How quickly can you get an electrician to ${town.name}?`,
    a: `For central Gippsland — Sale, Maffra, Stratford, Heyfield, Rosedale and surrounds — we can often do same-day. ${town.name} is on our regular run; call ${business.phone.display} and we'll give you a straight answer on timing.`,
  },
  {
    q: `What does an electrician callout cost in ${town.name}?`,
    a: `During business hours (Mon–Fri 7am–5pm, excluding public holidays) the service call is $149 inc GST and includes the first 30 minutes of labour on site. After that we bill at $125 per hour + GST in 30-minute blocks. Outside business hours it's $195 per hour + GST, charged from when we leave our Sale warehouse to when we return.`,
  },
  {
    q: "How do I know if I need a switchboard upgrade?",
    a: "If your board still has ceramic fuses, no safety switches on lighting circuits, or trips when appliances run together, it's overdue. Most older homes get a board replacement at the same time as a kitchen or bathroom reno so the whole house gets brought up to current standards at once.",
  },
  {
    q: "Can you install an EV charger?",
    a: "Yes — 7kW or 22kW residential wall units, with a supply upgrade if your existing board can't carry the load. Most installs are under a day.",
  },
  {
    q: "Do you do farm and three-phase work?",
    a: "Yes — sheds, pumps, dairies, machinery circuits. We use IP-rated enclosures and proper cable spec for rural environments, and document the install so future contractors aren't guessing.",
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Electrician — Residential & Commercial",
  "provider": {
    "@type": "Electrician",
    "name": business.name,
    "telephone": business.phone.international,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.address.street,
      "addressLocality": business.address.locality,
      "addressRegion": business.address.region,
      "postalCode": business.address.postcode,
      "addressCountry": business.address.country,
    },
  },
  "areaServed": {
    "@type": "City",
    "name": town.name,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": town.name,
      "postalCode": town.postcode,
      "addressRegion": "VIC",
      "addressCountry": "AU",
    },
  },
  "url": new URL(`/services/electrical/${town.slug}`, Astro.site).toString(),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Services", item: new URL("/services", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: "Electrical", item: new URL("/services/electrical", Astro.site).toString() },
    { "@type": "ListItem", position: 3, name: town.name, item: new URL(`/services/electrical/${town.slug}`, Astro.site).toString() },
  ],
};

const nearbyTowns = town.nearby
  .map((slug) => electricalTowns.find((t) => t.slug === slug))
  .filter((t): t is ElectricalTown => Boolean(t));
---
<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
    <Container class="relative py-20 md:py-24">
      <nav class="text-bone-400 text-sm flex flex-wrap items-center gap-2" aria-label="Breadcrumb">
        <a href="/services" class="hover:text-spark-500">Services</a>
        <span>/</span>
        <a href="/services/electrical" class="hover:text-spark-500">Electrical</a>
        <span>/</span>
        <span class="text-bone-200">{town.name}</span>
      </nav>
      <p class="mt-6 text-spark-500 tracking-[0.3em] text-xs font-bold">{town.region.toUpperCase()}{town.postcode ? ` · ${town.postcode}` : ""}</p>
      <h1 class="mt-3 text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1]">
        Licensed electrician<br />in <span class="text-spark-500">{town.name}.</span>
      </h1>
      <p class="mt-6 text-bone-200 max-w-2xl text-lg md:text-xl">
        {town.intro}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={`/contact?service=electrical&town=${town.slug}#quote-form`}>Book a {town.name} job</Button>
        <a href={`tel:${business.phone.tel}`} class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold tracking-wide uppercase transition-colors border border-ink-700 text-bone-50 hover:border-spark-500 hover:text-spark-500 whitespace-nowrap">
          Call {business.phone.display}
        </a>
      </div>
    </Container>
  </section>

  <!-- LOCAL CONTEXT -->
  <section class="py-20 border-b border-ink-800">
    <Container size="narrow">
      <SectionHeading eyebrow={`ELECTRICAL IN ${town.name.toUpperCase()}`} title={`What ${town.name} electrical work looks like.`} />
      <div class="mt-8 text-bone-200 text-lg leading-relaxed">
        {town.context}
      </div>
    </Container>
  </section>

  <!-- WHAT WE DO (short, town-scoped) -->
  <section class="py-20 border-b border-ink-800">
    <Container>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <SectionHeading eyebrow="WHAT WE DO" title={`Electrical service for ${town.name}.`} />
          <p class="mt-6 text-bone-200">
            From a fault-find through to a full board replacement, EV charger install, shed three-phase or new build — we cover the lot, properly, with the compliance paperwork at the end.
          </p>
          <div class="mt-8 flex gap-3">
            <Button href={`/contact?service=electrical&town=${town.slug}#quote-form`}>Get a quote</Button>
            <Button href="/services/electrical" variant="ghost">All electrical info</Button>
          </div>
        </div>
        <ul class="space-y-3">
          {[
            `Switchboard upgrades in ${town.name} homes`,
            "Safety switch (RCD) installation and testing",
            `Power-point and circuit additions in ${town.name}`,
            "Lighting design + install",
            "EV charger installation (residential + commercial)",
            "Three-phase for sheds, pumps and commercial",
            "Solar / battery interconnect electrical",
            "Fault finding and emergency callouts",
          ].map((s) => (
            <li class="flex gap-3 items-start text-bone-200 border-b border-ink-800 pb-3">
              <span class="text-spark-500 font-bold mt-0.5">→</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- RATES -->
  <section class="py-20 border-b border-ink-800">
    <Container>
      <SectionHeading eyebrow="RATES" title={`What an electrician costs in ${town.name}.`} description="Same rates across all of Gippsland — flat call-out, hourly labour after that. No surprises on the invoice." />
      <div class="mt-12 grid md:grid-cols-3 gap-px bg-ink-700 border border-ink-700">
        <div class="bg-ink-950 p-6 md:p-8">
          <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">{rates.serviceCall.label}</p>
          <p class="mt-3 text-bone-400 text-xs tracking-[0.2em] uppercase">{rates.serviceCall.tagline}</p>
          <p class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-bone-50">${rates.serviceCall.amount}<span class="text-spark-500 text-2xl ml-1 whitespace-nowrap">{rates.serviceCall.priceSuffix}</span></p>
          <p class="mt-3 text-bone-200 text-sm">{rates.serviceCall.detail}</p>
        </div>
        <div class="bg-ink-950 p-6 md:p-8">
          <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">{rates.continuingLabour.label}</p>
          <p class="mt-3 text-bone-400 text-xs tracking-[0.2em] uppercase">{rates.continuingLabour.tagline}</p>
          <p class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-bone-50">${rates.continuingLabour.amount}<span class="text-spark-500 text-2xl ml-1 whitespace-nowrap">{rates.continuingLabour.priceSuffix}</span></p>
          <p class="mt-3 text-bone-200 text-sm">{rates.continuingLabour.detail}</p>
        </div>
        <div class="bg-ink-950 p-6 md:p-8">
          <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">{rates.afterHours.label}</p>
          <p class="mt-3 text-bone-400 text-xs tracking-[0.2em] uppercase">{rates.afterHours.tagline}</p>
          <p class="mt-4 text-4xl md:text-5xl font-extrabold tracking-tight text-bone-50">${rates.afterHours.amount}<span class="text-spark-500 text-2xl ml-1 whitespace-nowrap">{rates.afterHours.priceSuffix}</span></p>
          <p class="mt-3 text-bone-200 text-sm">{rates.afterHours.detail}</p>
        </div>
      </div>
      <p class="mt-6 text-bone-400 text-sm">{rates.note} Materials (boards, switchgear, cable, fittings) are quoted on site.</p>
    </Container>
  </section>

  <!-- NEARBY TOWNS -->
  {nearbyTowns.length > 0 && (
    <section class="py-20 border-b border-ink-800">
      <Container>
        <SectionHeading eyebrow="NEARBY" title={`Other towns we cover near ${town.name}.`} />
        <div class="mt-12 grid sm:grid-cols-2 md:grid-cols-4 gap-px bg-ink-700 border border-ink-700">
          {nearbyTowns.map((t) => (
            <a
              href={`/services/electrical/${t.slug}`}
              class="group bg-ink-950 p-5 hover:bg-ink-900 transition-colors flex flex-col justify-between min-h-[140px]"
            >
              <div>
                <p class="text-spark-500 text-xs font-bold tracking-[0.2em] uppercase">Electrician in</p>
                <h3 class="mt-1 text-xl font-bold">{t.name}</h3>
                <p class="mt-2 text-bone-400 text-sm leading-snug">{t.teaser}</p>
              </div>
              <span class="mt-4 text-spark-500 text-sm font-semibold group-hover:translate-x-1 transition-transform">View →</span>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- FAQ -->
  <section class="py-20 border-b border-ink-800">
    <Container size="narrow">
      <SectionHeading eyebrow="FAQ" title={`Electrical questions, answered for ${town.name}.`} />
      <div class="mt-12 space-y-3">
        {faqs.map((f) => (
          <details class="border border-ink-800 bg-ink-900 group">
            <summary class="px-6 py-4 cursor-pointer text-bone-50 font-semibold flex items-center justify-between gap-4 hover:bg-ink-800 transition-colors">
              <span>{f.q}</span>
              <span class="text-spark-500 transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <div class="px-6 pb-5 text-bone-200 leading-relaxed">{f.a}</div>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- FINAL CTA -->
  <section class="py-20 bg-spark-500 text-ink-950">
    <Container class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-ink-950/70 tracking-[0.3em] text-xs font-bold">BOOK A {town.name.toUpperCase()} JOB</p>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">Electrician in {town.name}?</h2>
        <p class="mt-3 text-ink-950/80 max-w-xl">Tell us what's going on — board tripping, EV charger, renovation, new shed, full rewire. We'll come back with a quote, or roll a van out same-day if we can.</p>
      </div>
      <div class="flex flex-col gap-2">
        <a href={`/contact?service=electrical&town=${town.slug}#quote-form`} class="inline-flex items-center justify-center px-6 py-4 bg-ink-950 text-spark-500 font-bold tracking-wide uppercase text-sm hover:bg-ink-900 transition-colors">Request a quote →</a>
        <a href={`tel:${business.phone.tel}`} class="text-center text-ink-950 font-semibold underline whitespace-nowrap">or call {business.phone.display}</a>
      </div>
    </Container>
  </section>
</Base>
