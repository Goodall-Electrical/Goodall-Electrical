---
import Base from "../../layouts/Base.astro";
import Container from "../../components/ui/Container.astro";
import Button from "../../components/ui/Button.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import { business } from "../../data/business";

export const prerender = true;

const title = "Control & Automation for Venues — Gippsland | Goodall Electrical";
const description = "Lighting, HVAC, audio and venue-control automation across Gippsland. Bring the gear you've already paid for under one panel staff can actually run from a tablet.";

const problems = [
  { title: "Lighting scenes for staff",       body: "Dinner, gaming, function, close-up — preset scenes that staff trigger from a panel, not by working out which switch does what." },
  { title: "HVAC that schedules itself",       body: "Climate control on a schedule that matches trading hours, with manual override for unexpected functions. Energy savings pay back inside a year." },
  { title: "One panel for the whole venue",    body: "AV, lighting, HVAC, signage — combined onto a touch panel with labels that match how the venue actually operates." },
  { title: "After-hours auto-shutdown",       body: "Whole-of-venue power and HVAC shutdown at close, with security and emergency lighting kept on. Manager flicks one switch on the way out." },
  { title: "Integrating older equipment",      body: "We don't rip out gear that's working — we bridge older systems into a new control layer where it makes sense." },
  { title: "Energy monitoring",                body: "Per-circuit monitoring so you can see where the bills are coming from. Useful for sites trying to right-size their solar." },
];

const services = [
  "Lighting control (DMX, DALI, scene-based)",
  "HVAC integration + scheduling",
  "Whole-venue touch-panel control (Crestron, KNX, custom)",
  "Energy monitoring + after-hours shutdowns",
  "Integration with existing BMS systems",
  "Audio + AV control integration",
  "Emergency lighting + life-safety overrides",
  "Ongoing tuning and software updates",
];

const faqs = [
  {
    q: "Do I need expensive custom-coded gear, or are there standard products?",
    a: "Both work. For most venues a packaged system (Crestron Home, KNX, or a similar standard) costs less and is easier to service. We only go custom when the brief genuinely needs it — bespoke is fun to install but expensive to maintain.",
  },
  {
    q: "Can you integrate with our existing AV / lighting?",
    a: "Usually yes. Most modern AV and lighting gear has open control protocols (Crestron, RS-232, KNX, DMX, DALI, IP). We bridge what works into the new system rather than replacing equipment unnecessarily.",
  },
  {
    q: "How much does an automation system cost?",
    a: `Heavily dependent on the venue size and what you're integrating. A simple multi-zone lighting controller is a one-day install; a full venue control system with custom panels is weeks of design + install + commissioning. We quote on site. Service-call rate during business hours is $149 inc GST for the first 30 minutes, then $125 per hour + GST; after-hours is $195 per hour + GST.`,
  },
  {
    q: "Will it actually save energy?",
    a: "Done properly, yes — typically 15-30% off the lighting + HVAC bill in hospitality venues, mostly from scheduling and auto-shutdown rather than from any clever gear. The payback is usually 12-24 months.",
  },
  {
    q: "Who maintains it after the install?",
    a: "We do, if you want — we offer ongoing service contracts that cover software updates, panel re-tuning when seasons change, and remote diagnostics when something acts up. You can also self-manage if you've got the appetite.",
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Control & Automation Systems",
  "audience": { "@type": "Audience", "audienceType": "Hospitality venues, commercial sites" },
  "provider": {
    "@type": "Electrician",
    "name": business.name,
    "telephone": business.phone.international,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.address.street,
      "addressLocality": business.address.locality,
      "addressRegion": business.address.region,
      "postalCode": business.address.postcode,
      "addressCountry": business.address.country,
    },
  },
  "areaServed": business.serviceArea.full,
  "url": new URL("/services/control-automation", Astro.site).toString(),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---
<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
    <Container class="relative py-20 md:py-28">
      <a href="/services" class="text-spark-500 text-sm font-semibold">← All services</a>
      <p class="mt-6 text-spark-500 tracking-[0.3em] text-xs font-bold">CONTROL · AUTOMATION · GIPPSLAND</p>
      <h1 class="mt-3 text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1]">
        The best automation<br /><span class="text-spark-500">disappears.</span>
      </h1>
      <p class="mt-6 text-bone-200 max-w-2xl text-lg md:text-xl">
        Lighting, HVAC, AV and access — under one panel staff can actually run from a tablet. We bridge the gear you've already paid for into a control layer that matches how your venue actually operates.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="/contact#quote-form">Book a venue walkthrough</Button>
        <a href={`tel:${business.phone.tel}`} class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold tracking-wide uppercase transition-colors border border-ink-700 text-bone-50 hover:border-spark-500 hover:text-spark-500 whitespace-nowrap">
          Call {business.phone.display}
        </a>
      </div>
      <ul class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl text-sm text-bone-200">
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Lighting + HVAC scenes</li>
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Auto after-hours shutdown</li>
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Tablet control for staff</li>
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> 15-30% energy savings typical</li>
      </ul>
    </Container>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="py-20 border-b border-ink-800">
    <Container>
      <SectionHeading eyebrow="THE WORK" title="What we automate." description="The wins come from scheduling and integration, not gadgets. The right system saves money on bills, friction on operations, and yelling about which switch does what." />
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {problems.map((p) => (
          <div class="border border-ink-800 bg-ink-900 p-6 hover:border-spark-500 transition-colors">
            <h3 class="text-lg font-bold">{p.title}</h3>
            <p class="mt-3 text-bone-200 text-sm leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- WHAT WE DO -->
  <section class="py-20 border-b border-ink-800">
    <Container>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <SectionHeading eyebrow="WHAT WE DO" title="Standard kit + custom integration." />
          <p class="mt-6 text-bone-200">We default to packaged automation systems (Crestron, KNX) where they fit, because they're cheaper to maintain. Custom work only where the brief genuinely needs it. Either way, the result is a venue that runs itself between intentional staff actions.</p>
          <div class="mt-8 flex gap-3">
            <Button href="/contact#quote-form">Get a quote</Button>
            <Button href="/services" variant="ghost">All services</Button>
          </div>
        </div>
        <ul class="space-y-3">
          {services.map((s) => (
            <li class="flex gap-3 items-start text-bone-200 border-b border-ink-800 pb-3">
              <span class="text-spark-500 font-bold mt-0.5">→</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- FAQ -->
  <section class="py-20 border-b border-ink-800">
    <Container size="narrow">
      <SectionHeading eyebrow="FAQ" title="Automation questions, answered." />
      <div class="mt-12 space-y-3">
        {faqs.map((f) => (
          <details class="border border-ink-800 bg-ink-900 group">
            <summary class="px-6 py-4 cursor-pointer text-bone-50 font-semibold flex items-center justify-between gap-4 hover:bg-ink-800 transition-colors">
              <span>{f.q}</span>
              <span class="text-spark-500 transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <div class="px-6 pb-5 text-bone-200 leading-relaxed">{f.a}</div>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- FINAL CTA -->
  <section class="py-20 bg-spark-500 text-ink-950">
    <Container class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-ink-950/70 tracking-[0.3em] text-xs font-bold">BOOK A WALKTHROUGH</p>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">Got a control project in mind?</h2>
        <p class="mt-3 text-ink-950/80 max-w-xl">We'll walk the venue with you, see what's already in place, and come back with options ranged by spend and complexity. No charge for the visit.</p>
      </div>
      <div class="flex flex-col gap-2">
        <a href="/contact#quote-form" class="inline-flex items-center justify-center px-6 py-4 bg-ink-950 text-spark-500 font-bold tracking-wide uppercase text-sm hover:bg-ink-900 transition-colors">Request a quote →</a>
        <a href={`tel:${business.phone.tel}`} class="text-center text-ink-950 font-semibold underline whitespace-nowrap">or call {business.phone.display}</a>
      </div>
    </Container>
  </section>
</Base>
