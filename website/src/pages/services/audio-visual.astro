---
import Base from "../../layouts/Base.astro";
import Container from "../../components/ui/Container.astro";
import Button from "../../components/ui/Button.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import { business } from "../../data/business";
import { getCollection } from "astro:content";

export const prerender = true;

const title = "Audio Visual for Pubs, Clubs & Venues — Gippsland | Goodall Electrical";
const description = "Pub and club AV across Gippsland — sports-bar source switching, multi-zone audio, screen networks, projector installs, function-room flexibility. Designed for venue staff to operate without a tech.";

const problems = [
  { title: "Sports-bar source switching",  body: "Foxtel, Sky Racing, free-to-air, streaming — switched centrally and routed to the right screens. Staff change source from a tablet, not a remote pile." },
  { title: "Audio that won't cover the room", body: "Wrong speaker spec or placement is the usual culprit. We measure coverage with proper tools, spec speakers to suit, and tune the zones so race calling carries and background music doesn't drown the bar." },
  { title: "Multiple zones, one mess",       body: "Front bar, beer garden, gaming, function room — each needs independent control. We design proper zone matrices so one room's music doesn't follow into another." },
  { title: "Projector or big-screen install", body: "Projector mount + screen + source distribution + audio sync — done so the function room is one-button to operate when staff need it on Friday night." },
  { title: "Staff who don't want a manual",   body: "Touch-panel control with the buttons labelled for what staff actually do (\"Dinner mode\", \"Race day\", \"Wednesday meat raffle\") — not technical jargon." },
  { title: "Mixing old + new gear",           body: "We integrate with the equipment you've already invested in where it makes sense, and replace only the weak links — not the whole system." },
];

const services = [
  "Sports-bar source switching (Foxtel, Sky Racing, FTA, streaming)",
  "Multi-zone audio design + install (PA, background, function rooms)",
  "TV / screen networks and digital signage",
  "Projector installation and ceiling/wall mounts",
  "Microphone, mixing and live-event audio",
  "Touch-panel control for venue staff",
  "Equipment racks, cable management, comms-room tidy-ups",
  "Ongoing maintenance and event-night support",
];

const projects = (await getCollection("projects"))
  .filter((p) => p.data.services.includes("audio-visual"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const faqs = [
  {
    q: "Do you only work with pubs and clubs?",
    a: "No — we do the full hospitality range plus motels, function venues, sporting clubs, and small commercial sites. The common thread is venues where staff need to operate AV without a tech standing by. We don't do home theatre.",
  },
  {
    q: "How much does a venue AV upgrade cost?",
    a: `Highly variable — a single projector install is one day's work; a full venue AV refit (multi-room, multi-zone, control panels) is weeks of design + install + commissioning. We quote on site after walking through the venue. Service-call rate during business hours is $149 inc GST for the first 30 minutes, then $125 per hour + GST. After-hours work is $195 per hour + GST.`,
  },
  {
    q: "Can you work around our event schedule?",
    a: "Yes — we coordinate the install around your trading hours, including overnight work for venues that can't go offline. We've done venue refits without missing a Saturday night.",
  },
  {
    q: "What gear do you use?",
    a: "Whatever the room and budget call for — we don't have a single-brand bias. We spec based on coverage requirements, environment (gaming-floor humidity, beer-garden weather, kitchen heat) and what's serviceable locally.",
  },
  {
    q: "Do you handle the electrical work too?",
    a: "Yes — we're licensed electricians as well. Single crew handles the AV, the electrical, the data cabling and the rack work. One quote, one invoice, one point of contact.",
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Commercial Audio Visual Installation",
  "audience": { "@type": "Audience", "audienceType": "Hospitality venues, commercial sites" },
  "provider": {
    "@type": "Electrician",
    "name": business.name,
    "telephone": business.phone.international,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": business.address.street,
      "addressLocality": business.address.locality,
      "addressRegion": business.address.region,
      "postalCode": business.address.postcode,
      "addressCountry": business.address.country,
    },
  },
  "areaServed": business.serviceArea.full,
  "url": new URL("/services/audio-visual", Astro.site).toString(),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---
<Base title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
    <Container class="relative py-20 md:py-28">
      <a href="/services" class="text-spark-500 text-sm font-semibold">← All services</a>
      <p class="mt-6 text-spark-500 tracking-[0.3em] text-xs font-bold">VENUE AV · HOSPITALITY · GIPPSLAND</p>
      <h1 class="mt-3 text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-[1]">
        Venue AV that<br />staff can <span class="text-spark-500">actually run.</span>
      </h1>
      <p class="mt-6 text-bone-200 max-w-2xl text-lg md:text-xl">
        Pub, club, hotel and function-room AV across Gippsland. Sports-bar source switching, multi-zone audio, screen networks, projector installs and touch-panel control — engineered to handle race day, then disappear into the background on Tuesday.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href="/contact#quote-form">Book a venue walkthrough</Button>
        <a href={`tel:${business.phone.tel}`} class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold tracking-wide uppercase transition-colors border border-ink-700 text-bone-50 hover:border-spark-500 hover:text-spark-500 whitespace-nowrap">
          Call {business.phone.display}
        </a>
      </div>
      <ul class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl text-sm text-bone-200">
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Race-day source switching</li>
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Multi-zone audio</li>
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Staff-friendly control</li>
        <li class="flex items-start gap-2"><span class="text-spark-500">⚡</span> Electrical + AV under one roof</li>
      </ul>
    </Container>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="py-20 border-b border-ink-800">
    <Container>
      <SectionHeading eyebrow="THE WORK" title="What venue AV usually looks like." description="The gear is the easy part. Designing for the way the venue actually runs is what separates a job that lasts from a job that gets ripped out in two years." />
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {problems.map((p) => (
          <div class="border border-ink-800 bg-ink-900 p-6 hover:border-spark-500 transition-colors">
            <h3 class="text-lg font-bold">{p.title}</h3>
            <p class="mt-3 text-bone-200 text-sm leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- WHAT WE DO -->
  <section class="py-20 border-b border-ink-800">
    <Container>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <SectionHeading eyebrow="WHAT WE DO" title="Full venue AV, in-house." />
          <p class="mt-6 text-bone-200">From a single projector mount through to a multi-room, multi-zone refit with custom control panels. We design it, install it, commission it, and train the staff on it — same team start to finish.</p>
          <div class="mt-8 flex gap-3">
            <Button href="/contact#quote-form">Get a quote</Button>
            <Button href="/projects" variant="ghost">See our venue work</Button>
          </div>
        </div>
        <ul class="space-y-3">
          {services.map((s) => (
            <li class="flex gap-3 items-start text-bone-200 border-b border-ink-800 pb-3">
              <span class="text-spark-500 font-bold mt-0.5">→</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- FEATURED PROJECTS -->
  {projects.length > 0 && (
    <section class="py-20 border-b border-ink-800">
      <Container>
        <div class="flex items-end justify-between gap-6 flex-wrap">
          <SectionHeading eyebrow="RECENT WORK" title="Venues we've wired for AV." />
          <a href="/projects" class="text-spark-500 text-sm font-semibold hover:text-spark-600">All projects →</a>
        </div>
        <div class="mt-12 grid md:grid-cols-3 gap-6">
          {projects.map((p) => (
            <a href={`/projects/${p.data.slug}`} class="group block bg-ink-900 border border-ink-800 hover:border-spark-500 transition-colors">
              <div class="aspect-[4/3] bg-ink-800 overflow-hidden">
                <img src={p.data.heroImage} alt={p.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
              </div>
              <div class="p-5">
                <p class="text-spark-500 text-xs font-bold tracking-[0.2em] uppercase">{p.data.category}</p>
                <h3 class="mt-2 text-lg font-bold">{p.data.title}</h3>
                <p class="mt-1 text-bone-400 text-sm">{p.data.client} · {p.data.year}</p>
              </div>
            </a>
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- FAQ -->
  <section class="py-20 border-b border-ink-800">
    <Container size="narrow">
      <SectionHeading eyebrow="FAQ" title="Venue AV questions, answered." />
      <div class="mt-12 space-y-3">
        {faqs.map((f) => (
          <details class="border border-ink-800 bg-ink-900 group">
            <summary class="px-6 py-4 cursor-pointer text-bone-50 font-semibold flex items-center justify-between gap-4 hover:bg-ink-800 transition-colors">
              <span>{f.q}</span>
              <span class="text-spark-500 transition-transform group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <div class="px-6 pb-5 text-bone-200 leading-relaxed">{f.a}</div>
          </details>
        ))}
      </div>
    </Container>
  </section>

  <!-- FINAL CTA -->
  <section class="py-20 bg-spark-500 text-ink-950">
    <Container class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <div>
        <p class="text-ink-950/70 tracking-[0.3em] text-xs font-bold">BOOK A WALKTHROUGH</p>
        <h2 class="mt-3 text-3xl md:text-5xl font-extrabold tracking-tight">Got a venue AV job in mind?</h2>
        <p class="mt-3 text-ink-950/80 max-w-xl">We'll come out, walk through the rooms with you, and come back with a proper scope and quote. No charge for the visit.</p>
      </div>
      <div class="flex flex-col gap-2">
        <a href="/contact#quote-form" class="inline-flex items-center justify-center px-6 py-4 bg-ink-950 text-spark-500 font-bold tracking-wide uppercase text-sm hover:bg-ink-900 transition-colors">Request a quote →</a>
        <a href={`tel:${business.phone.tel}`} class="text-center text-ink-950 font-semibold underline whitespace-nowrap">or call {business.phone.display}</a>
      </div>
    </Container>
  </section>
</Base>
