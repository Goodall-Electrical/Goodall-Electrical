---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Container from "../../components/ui/Container.astro";
import Button from "../../components/ui/Button.astro";
import { business } from "../../data/business";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateFmt = new Intl.DateTimeFormat("en-AU", { day: "numeric", month: "long", year: "numeric" });
const isoDate = (d: Date) => d.toISOString().slice(0, 10);

// Related posts — same category, excluding this one.
const allPosts = await getCollection("posts");
const related = allPosts
  .filter((p) => p.data.slug !== post.data.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": isoDate(post.data.publishedAt),
  ...(post.data.updatedAt ? { dateModified: isoDate(post.data.updatedAt) } : {}),
  "author": { "@type": "Organization", "name": business.name, "url": business.url },
  "publisher": {
    "@type": "Organization",
    "name": business.name,
    "url": business.url,
    "logo": { "@type": "ImageObject", "url": new URL("/logo.png", business.url).toString() },
  },
  "mainEntityOfPage": new URL(`/blog/${post.data.slug}`, Astro.site).toString(),
  "articleSection": post.data.category,
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", position: 1, name: "Blog", item: new URL("/blog", Astro.site).toString() },
    { "@type": "ListItem", position: 2, name: post.data.title, item: new URL(`/blog/${post.data.slug}`, Astro.site).toString() },
  ],
};
---
<Base title={`${post.data.title} — Goodall Electrical`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script>

  <article>
    <!-- HEAD -->
    <section class="relative overflow-hidden border-b border-ink-800">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
      <Container class="relative py-20 md:py-24" size="narrow">
        <nav class="text-bone-400 text-sm flex flex-wrap items-center gap-2" aria-label="Breadcrumb">
          <a href="/blog" class="hover:text-spark-500">Blog</a>
          <span>/</span>
          <span class="text-bone-200">{post.data.category}</span>
        </nav>
        <p class="mt-6 text-spark-500 tracking-[0.3em] text-xs font-bold uppercase">{post.data.category}</p>
        <h1 class="mt-3 text-3xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.05]">{post.data.title}</h1>
        <p class="mt-6 text-bone-200 text-lg md:text-xl">{post.data.description}</p>
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-bone-400">
          <span>{dateFmt.format(post.data.publishedAt)}</span>
          {post.data.readingMinutes && <span>· {post.data.readingMinutes} min read</span>}
          <span>· by {business.name}</span>
        </div>
      </Container>
    </section>

    <!-- BODY -->
    <section class="py-16 md:py-20">
      <Container size="narrow">
        <div class="prose-invert">
          <Content />
        </div>

        <div class="mt-16 pt-8 border-t border-ink-800 flex flex-wrap gap-3">
          <Button href="/contact#quote-form">Get a quote</Button>
          <Button href="/blog" variant="ghost">More articles</Button>
        </div>
      </Container>
    </section>

    {related.length > 0 && (
      <section class="py-16 border-t border-ink-800 bg-ink-950">
        <Container>
          <p class="text-spark-500 text-xs font-bold tracking-[0.3em] uppercase">Related</p>
          <h2 class="mt-3 text-2xl md:text-3xl font-extrabold tracking-tight">More {post.data.category.toLowerCase()} reading.</h2>
          <div class="mt-10 grid md:grid-cols-3 gap-6">
            {related.map((p) => (
              <a href={`/blog/${p.data.slug}`} class="group block bg-ink-900 border border-ink-800 hover:border-spark-500 transition-colors p-6">
                <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">{p.data.category}</p>
                <h3 class="mt-3 text-lg font-bold leading-snug group-hover:text-spark-500 transition-colors">{p.data.title}</h3>
                <p class="mt-2 text-bone-400 text-sm leading-snug">{p.data.description}</p>
              </a>
            ))}
          </div>
        </Container>
      </section>
    )}
  </article>
</Base>

<style is:global>
  /* Article body styling — applied via .prose-invert so it doesn't bleed into other pages. */
  .prose-invert h2 {
    color: var(--color-bone-50);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .prose-invert h3 {
    color: var(--color-bone-50);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
  }
  .prose-invert p, .prose-invert li {
    color: var(--color-bone-200);
    line-height: 1.75;
  }
  .prose-invert p { margin-top: 1.25rem; }
  .prose-invert ul, .prose-invert ol { list-style: disc; padding-left: 1.5rem; margin-top: 1rem; }
  .prose-invert ol { list-style: decimal; }
  .prose-invert ul li, .prose-invert ol li { margin-top: 0.5rem; }
  .prose-invert strong { color: var(--color-bone-50); }
  .prose-invert a {
    color: var(--color-spark-500);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .prose-invert a:hover { color: var(--color-spark-600); }
  .prose-invert blockquote {
    border-left: 4px solid var(--color-spark-500);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-bone-50);
  }
  .prose-invert table {
    width: 100%;
    margin-top: 1.5rem;
    border-collapse: collapse;
    font-size: 0.95rem;
  }
  .prose-invert th, .prose-invert td {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-ink-700);
  }
  .prose-invert th {
    color: var(--color-spark-500);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }
  .prose-invert code {
    background: var(--color-ink-900);
    padding: 0.15em 0.4em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
  }
</style>
