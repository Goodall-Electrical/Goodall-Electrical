---
import Base from "../layouts/Base.astro";
import Container from "../components/ui/Container.astro";
import QuoteForm from "../components/forms/QuoteForm.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";

const status = Astro.url.searchParams.get("status");

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "Electrician",
  "name": "Goodall Electrical",
  "telephone": "+61341305012",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Unit 5/9 Wellington Park Way",
    "addressLocality": "Sale",
    "addressRegion": "VIC",
    "postalCode": "3850",
    "addressCountry": "AU",
  },
  "areaServed": "Gippsland, Victoria, Australia",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "07:00",
      "closes": "17:00",
    },
  ],
};

const next = [
  { n: "01", title: "We see your message", body: "Submissions land in our office inbox within seconds." },
  { n: "02", title: "We get back to you", body: "Within one business day — usually faster. We'll call or reply by email, whichever you prefer." },
  { n: "03", title: "We arrange the work", body: "If it needs a site visit, we book a time. If it's a quick quote, we send it straight through." },
];
---
<Base title="Contact — Goodall Electrical" description="Get in touch with Goodall Electrical — phone, contact form, or visit our Sale office. Servicing all of Gippsland.">
  <script type="application/ld+json" set:html={JSON.stringify(localBusiness)}></script>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-ink-800">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-spark-500)_0%,_transparent_50%)] opacity-10"></div>
    <Container class="relative py-20 md:py-28">
      <p class="text-spark-500 tracking-[0.3em] text-xs font-bold">GET IN TOUCH</p>
      <h1 class="mt-3 text-5xl md:text-7xl font-extrabold tracking-tight leading-[1]">
        Let's <span class="text-spark-500">talk.</span>
      </h1>
      <p class="mt-6 text-bone-200 max-w-2xl text-lg md:text-xl">
        Quotes, callouts, maintenance, advice — we're easy to get hold of. Call for anything urgent, or send a message and we'll be back to you within a business day.
      </p>

    </Container>
  </section>

  <!-- SUCCESS MODAL (opens automatically when ?status=ok lands) -->
  <dialog id="success-modal" class="success-modal" aria-labelledby="success-title">
    <div class="bg-ink-950 border border-ink-700 border-l-4 border-l-spark-500 max-w-md w-full p-8 text-bone-50">
      <div class="flex items-center gap-3">
        <span class="inline-flex h-10 w-10 items-center justify-center bg-spark-500 text-ink-950">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12l5 5 9-11"/>
          </svg>
        </span>
        <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">Message received</p>
      </div>
      <h2 id="success-title" class="mt-5 text-3xl font-extrabold tracking-tight leading-tight">
        Thanks — we've <span class="text-spark-500">got it.</span>
      </h2>
      <p class="mt-4 text-bone-200 leading-relaxed">
        A team member will be in touch within one business day. For anything urgent, call
        <a href="tel:0341305012" class="text-spark-500 font-semibold hover:text-spark-600 whitespace-nowrap">03 4130 5012</a>.
      </p>
      <div class="mt-7 flex flex-wrap gap-3 justify-end">
        <a href="/" class="px-5 py-3 border border-ink-700 text-bone-50 text-sm font-semibold tracking-wide uppercase hover:border-spark-500 hover:text-spark-500 transition-colors">Back to home</a>
        <button type="button" data-close-modal class="px-5 py-3 bg-spark-500 text-ink-950 text-sm font-semibold tracking-wide uppercase hover:bg-spark-600 transition-colors">Got it</button>
      </div>
    </div>
  </dialog>

  <style is:global>
    .success-modal {
      padding: 0;
      border: none;
      background: transparent;
      color: inherit;
      max-width: none;
      max-height: none;
      width: 100%;
      animation: success-pop 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    .success-modal::backdrop {
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .success-modal[open] {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    @keyframes success-pop {
      from { opacity: 0; transform: translateY(12px) scale(0.98); }
      to   { opacity: 1; transform: translateY(0)    scale(1);    }
    }
    @media (prefers-reduced-motion: reduce) {
      .success-modal { animation: none; }
    }
  </style>

  <script is:inline define:vars={{ showModal: status === "ok" }}>
    const modal = document.getElementById("success-modal");
    if (modal) {
      const close = () => {
        if (typeof modal.close === "function") modal.close();
        else modal.removeAttribute("open");
      };

      if (showModal) {
        if (typeof modal.showModal === "function") modal.showModal();
        else modal.setAttribute("open", "");
        // Strip ?status=ok from the URL so a refresh doesn't re-open the modal.
        try {
          history.replaceState({}, "", window.location.pathname + window.location.hash);
        } catch {}
      }

      // Close on backdrop click (clicking the dialog element itself, not its child).
      modal.addEventListener("click", (e) => {
        if (e.target === modal) close();
      });
      // Close on any element with [data-close-modal]
      modal.querySelectorAll("[data-close-modal]").forEach((el) => el.addEventListener("click", close));
    }
  </script>

  <!-- URGENT vs. STANDARD strip -->
  <section class="border-b border-ink-800">
    <Container class="py-10 grid md:grid-cols-2 gap-px bg-ink-700 border border-ink-700">
      <a href="tel:0341305012" class="bg-spark-500 text-ink-950 p-8 hover:bg-spark-600 transition-colors group">
        <p class="text-ink-950/70 text-xs font-bold tracking-[0.25em] uppercase">Urgent? Right now?</p>
        <p class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight whitespace-nowrap">03 4130 5012</p>
        <p class="mt-3 text-ink-950/80 text-sm">Tap to call · Phones are answered during business hours, with an after-hours message for emergencies.</p>
      </a>
      <a href="#quote-form" class="bg-ink-900 p-8 hover:bg-ink-800 transition-colors group">
        <p class="text-bone-400 text-xs font-bold tracking-[0.25em] uppercase">Need a quote?</p>
        <p class="mt-3 text-2xl md:text-3xl font-extrabold tracking-tight text-bone-50">Use the form below →</p>
        <p class="mt-3 text-bone-400 text-sm">Tell us the basics — job type, site, urgency, what you need. Goes straight to our office.</p>
      </a>
    </Container>
  </section>

  <!-- CONTACT METHODS GRID -->
  <section class="border-b border-ink-800">
    <Container class="py-16 md:py-20 grid md:grid-cols-3 gap-px bg-ink-700 border border-ink-700">
      <div class="bg-ink-950 p-6">
        <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">Phone</p>
        <a href="tel:0341305012" class="mt-3 block text-2xl font-bold text-bone-50 hover:text-spark-500 transition-colors whitespace-nowrap">03 4130 5012</a>
        <p class="mt-2 text-bone-400 text-sm">+61 3 4130 5012<br />Mon–Fri · 7am–5pm</p>
      </div>
      <div class="bg-ink-950 p-6">
        <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">Service area</p>
        <p class="mt-3 text-bone-50 font-bold text-lg leading-snug">All of Gippsland</p>
        <p class="mt-1 text-bone-400 text-sm">Sale, Maffra, Stratford, Bairnsdale, Traralgon, Morwell &amp; surrounds.</p>
      </div>
      <div class="bg-ink-950 p-6">
        <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">Business</p>
        <p class="mt-3 text-bone-50 font-bold text-lg leading-snug">Goodall Electrical</p>
        <p class="mt-1 text-bone-400 text-sm">ACN 684 711 224<br />Fully licensed &amp; insured.</p>
      </div>
    </Container>
  </section>

  <!-- FORM + WHAT TO EXPECT -->
  <section id="quote-form" class="border-b border-ink-800 scroll-mt-24">
    <Container class="py-20 md:py-24 grid lg:grid-cols-2 gap-16">
      <div>
        <SectionHeading eyebrow="REQUEST A QUOTE" title="Tell us the job." description="The more detail you give us, the better the first reply will be — what the job is, where, and how soon you'd like it sorted." />
        <div class="mt-10">
          <QuoteForm returnTo="/contact" />
        </div>
      </div>

      <div>
        <p class="text-spark-500 tracking-[0.3em] text-xs font-bold">WHAT HAPPENS NEXT</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight">From message to job.</h2>
        <ol class="mt-10 space-y-6">
          {next.map((step) => (
            <li class="border-l-2 border-spark-500 pl-6">
              <p class="text-spark-500 font-bold text-sm tracking-[0.25em]">{step.n} — {step.title.toUpperCase()}</p>
              <p class="mt-2 text-bone-200 leading-relaxed">{step.body}</p>
            </li>
          ))}
        </ol>

        <div class="mt-12 border border-ink-800 bg-ink-900 p-6">
          <p class="text-spark-500 text-xs font-bold tracking-[0.25em] uppercase">A note on response time</p>
          <p class="mt-2 text-bone-200 text-sm leading-relaxed">
            We're a small team on the tools, so we won't reply at midnight. Messages sent during the day usually get answered the same afternoon. Anything time-critical — power off, no signal before the weekend, a job that has to start Monday — call the office and we'll triage in person.
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- SERVICE AREA TEASER -->
  <section class="py-16 md:py-20">
    <Container class="text-center">
      <p class="text-spark-500 tracking-[0.3em] text-xs font-bold">WHERE WE WORK</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-extrabold tracking-tight">Servicing every town in Gippsland.</h2>
      <p class="mt-4 text-bone-200 max-w-xl mx-auto">
        From Newry to Loch Sport, Bairnsdale to Warragul — if you're in the region, we cover you.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/services/antennas" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold tracking-wide uppercase transition-colors bg-spark-500 text-ink-950 hover:bg-spark-600">
          See all service areas →
        </a>
        <a href="/services" class="inline-flex items-center justify-center px-5 py-3 text-sm font-semibold tracking-wide uppercase transition-colors border border-ink-700 text-bone-50 hover:border-spark-500 hover:text-spark-500">
          Browse services
        </a>
      </div>
    </Container>
  </section>
</Base>
