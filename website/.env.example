# Copy to .env and fill in real values.
# Do NOT commit .env — it's gitignored.

# ── Outbound mail (used as a best-effort copy alongside Fergus) ──────
# Configure your Microsoft 365, Google Workspace, or transactional
# provider (Resend/Postmark) SMTP details here. Set SMTP_PORT=465 for
# implicit TLS or 587 for STARTTLS.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM="Goodall Electrical <no-reply@goodallelectrical.com.au>"

# Where contact + quote form notifications land.
GOODALL_INBOX=office@goodallelectrical.com.au

# ── Fergus API — primary lead destination ────────────────────────────
# Generate a Personal Access Token in Fergus → Settings → API.
FERGUS_API_BASE=https://api.fergus.com
FERGUS_API_KEY=fergPAT_replace-me

# ── Form behaviour ──────────────────────────────────────────────────
# Per-IP submission ceiling (anti-spam). Default 5/hr if unset.
RATE_LIMIT_PER_HOUR=5

# Canonical JSONL log of every submission (survives email/Fergus failures).
# In Docker this should point at the mounted volume.
SUBMISSION_LOG_PATH=/var/log/goodall/submissions.jsonl
